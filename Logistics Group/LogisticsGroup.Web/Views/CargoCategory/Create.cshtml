@model LogisticsGroup.Domain.Entities.CargoCategory

@{
    ViewData["Title"] = "Додати категорію";
}

<div class="container p-3">
    <div class="row pt-4">
        <h2 class="text-primary">Створити нову категорію вантажу</h2>
        <hr />
    </div>

    <form method="post" asp-action="Create">
        <div class="border p-3 mt-4">
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Назва категорії (напр. Габаритні, Крихкі)</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MinWeight" class="form-label">Мінімальна вага (кг)</label>
                <input asp-for="MinWeight" type="number" step="0.1" class="form-control" />
                <span asp-validation-for="MinWeight" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaxWeight" class="form-label">Максимальна вага (кг)</label>
                <input asp-for="MaxWeight" type="number" step="0.1" class="form-control" />
                <span asp-validation-for="MaxWeight" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary" style="width:150px">Зберегти</button>
                <a asp-controller="CargoCategory" asp-action="Index" class="btn btn-secondary" style="width:150px">
                    Скасувати
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}