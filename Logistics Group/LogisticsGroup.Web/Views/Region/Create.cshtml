@model LogisticsGroup.Domain.Entities.Region

@{
    ViewData["Title"] = "Додати область";
}

<div class="container p-3">
    <div class="row pt-4">
        <h2 class="text-primary">Створити нову область</h2>
        <hr />
    </div>

    <form method="post" asp-action="Create">
        <div class="border p-3 mt-4">
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Назва області (напр. Київська, Хмельницька)</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary" style="width:150px">Зберегти</button>
                <a asp-controller="Region" asp-action="Index" class="btn btn-secondary" style="width:150px">
                    Скасувати
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}