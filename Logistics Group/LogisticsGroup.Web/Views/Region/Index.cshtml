@model IEnumerable<LogisticsGroup.Domain.Entities.Region>

@{
    ViewData["Title"] = "Області";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Список областей</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Region" asp-action="Create" class="btn btn-primary">
                Додати нову область
            </a>
        </div>
    </div>
    <br /><br />

    <table class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>Назва області</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var obj in Model)
                {
                    <tr>
                        <td width="70%">@obj.Name</td>
                        <td class="text-center">
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Region" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-warning mx-2">
                                    Редагувати
                                </a>
                                <a asp-controller="Region" asp-action="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2">
                                    Видалити
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2" class="text-center">Областей поки що немає.</td>
                </tr>
            }
        </tbody>
    </table>
</div>