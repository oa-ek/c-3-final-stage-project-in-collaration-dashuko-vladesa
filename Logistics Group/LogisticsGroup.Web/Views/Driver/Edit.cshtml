@model LogisticsGroup.Domain.Entities.Driver

@{
    ViewData["Title"] = "Редагувати водія";
}

<div class="container p-3">
    <div class="row pt-4">
        <h2 class="text-primary">Редагувати дані водія</h2>
        <hr />
    </div>

    <form method="post" asp-action="Edit">
        
        <input type="hidden" asp-for="Id" />

        <div class="border p-3 mt-4">
            
            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Ім'я водія (ПІБ)</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label">Номер телефону</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-success" style="width:150px">Оновити</button>
                <a asp-controller="Driver" asp-action="Index" class="btn btn-secondary" style="width:150px">
                    Скасувати
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}