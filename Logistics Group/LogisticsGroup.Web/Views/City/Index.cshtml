@model IEnumerable<LogisticsGroup.Domain.Entities.City>

@{
    ViewData["Title"] = "Міста";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Список міст</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="City" asp-action="Create" class="btn btn-primary">
                Додати нове місто
            </a>
        </div>
    </div>
    <br /><br />

    <table class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>Назва</th>
                <th>Тип</th>
                <th>Область</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var obj in Model)
                {
                    <tr>
                        <td width="30%">@obj.Name</td>
                        <td width="20%">@obj.Type</td>
                        <td width="30%">@(obj.Region != null ? obj.Region.Name : "Не вказано")</td>
                        <td class="text-center">
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="City" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-warning mx-2">Редагувати</a>
                                <a asp-controller="City" asp-action="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2">Видалити</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center">Міст поки що немає.</td></tr>
            }
        </tbody>
    </table>
</div>