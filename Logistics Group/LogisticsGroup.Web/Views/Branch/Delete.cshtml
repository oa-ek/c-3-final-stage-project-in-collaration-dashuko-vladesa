@model LogisticsGroup.Domain.Entities.Branch

@{
    ViewData["Title"] = "Видалити відділення";
}

<div class="container p-3">
    <div class="row pt-4">
        <h2 class="text-danger">Видалити відділення</h2>
        <hr />
    </div>

    <h3 class="text-center">Ви впевнені, що хочете закрити це відділення?</h3>

    <div class="border p-3 mt-4">
        <div class="mb-3">
            <label class="form-label">Місто</label>
            <input value="@(Model.City != null ? Model.City.Name : "")" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Number" class="form-label">Номер відділення</label>
            <input asp-for="Number" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Address" class="form-label">Адреса</label>
            <input asp-for="Address" disabled class="form-control" />
        </div>

        <form method="post" asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="mt-4">
                <button type="submit" class="btn btn-danger" style="width:150px">Так, видалити</button>
                <a asp-controller="Branch" asp-action="Index" class="btn btn-secondary" style="width:150px">Ні, скасувати</a>
            </div>
        </form>
    </div>
</div>